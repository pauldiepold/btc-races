{
  "name": "btc-races-cron-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config ./wrangler.toml --env=\"\"",
    "deploy": "wrangler deploy --config ./wrangler.toml --env=\"\"",
    "deploy:preview": "wrangler deploy --config ./wrangler.toml --env preview",
    "tail": "wrangler tail --config ./wrangler.toml --env=\"\"",
    "tail:preview": "wrangler tail --config ./wrangler.toml --env preview",
    "secret:set": "wrangler secret put CRON_TOKEN --config ./wrangler.toml --env=\"\"",
    "secret:set:preview": "wrangler secret put CRON_TOKEN --config ./wrangler.toml --env preview"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260422.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.84.1"
  }
}
