{
  "name": "btc-races-2",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxi typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "nuxt db generate",
    "db:migrate": "nuxt db migrate",
    "db:remote:prod": "wrangler d1 migrations list btc-races-prod --remote",
    "db:remote:preview": "wrangler d1 migrations list btc-races-preview --remote --env preview",
    "db:remote:migrate:prod": "wrangler d1 migrations apply btc-races-prod --remote",
    "db:remote:migrate:preview": "wrangler d1 migrations apply btc-races-preview --remote --env preview",
    "seed:prod": "curl -s -X POST https://events.berlin-track-club.de/api/cron/seed -H \"Authorization: Bearer $NUXT_CRON_TOKEN\"",
    "seed:preview": "curl -s -X POST https://develop.btc-races.pages.dev/api/cron/seed -H \"Authorization: Bearer $NUXT_CRON_TOKEN\"",
    "sync:members:preview": "curl -s -X POST https://develop.btc-races.pages.dev/api/cron/sync-members -H \"Authorization: Bearer $NUXT_CRON_TOKEN\"",
    "sync:members:prod": "curl -s -X POST https://btc-races.pages.dev/api/cron/sync-members -H \"Authorization: Bearer $NUXT_CRON_TOKEN\"",
    "db:login": "wrangler login --no-browser",
    "prepare": "husky"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "@libsql/client": "^0.17.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/scripts": "1.0.1",
    "@nuxt/ui": "^4.6.1",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/turnstile": "1.1.2",
    "@pinia/colada": "^1.2.0",
    "@pinia/colada-nuxt": "^0.3.2",
    "@pinia/nuxt": "^0.11.3",
    "@takumi-rs/core": "^1.0.12",
    "@takumi-rs/wasm": "^1.0.12",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-email-renderer": "2.6.0",
    "nuxt-og-image": "^6.4.3",
    "pinia": "^3.0.4",
    "sqids": "^0.3.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "wrangler": "^4.83.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/eslint": "^1.15.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
