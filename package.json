{
  "name": "btc-races-2",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxi typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "nuxt db generate",
    "db:migrate": "nuxt db migrate",
    "db:remote": "wrangler d1 migrations list btc-races-prod --remote",
    "db:remote:migrate": "wrangler d1 migrations apply btc-races-prod --remote",
    "api:generate": "openapi-typescript server/external-apis/schemas/ladv-api-schema.json -o server/external-apis/ladv/generated/types.ts && openapi-typescript server/external-apis/schemas/campai-api-schema.json -o server/external-apis/campai/generated/types.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.6.0",
    "@nuxthub/core": "^0.10.7",
    "@pinia/colada": "^1.1.0",
    "@pinia/colada-nuxt": "^0.3.2",
    "@pinia/nuxt": "^0.11.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-email-renderer": "2.6.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "wrangler": "^4.79.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.101",
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6"
  }
}
